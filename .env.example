# Copy this file to .env and add your real xAI key.
# Never paste real API keys into chat or commit them to Git.
XAI_API_KEY=xai-your-key-here

# Defaults are chosen for quality and concise video output.
XAI_ANALYSIS_MODEL=grok-4.5
XAI_VIDEO_MODEL=grok-imagine-video
FIRSTVID_VIDEO_SECONDS=auto
FIRSTVID_VIDEO_RESOLUTION=480p
FIRSTVID_VIDEO_TIMEOUT_MS=180000
PORT=8788
